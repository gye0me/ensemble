        <circle cx="121" cy="94" r="2" fill="white"/>
        <circle cx="55" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
        <circle cx="145" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
        <ellipse cx="100" cy="128" rx="6" ry="8" fill="#ff6b9d"/>
    </svg>

    <svg class="dog-decoration dog-bottom-right" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="100" cy="110" rx="55" ry="58" fill="#fdd835" stroke="#f9a825" stroke-width="2"/>
        <ellipse cx="60" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(-20 60 55)"/>
        <ellipse cx="62" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(-20 62 58)"/>
        <ellipse cx="140" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(20 140 55)"/>
        <ellipse cx="138" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(20 138 58)"/>
        <ellipse cx="100" cy="110" rx="8" ry="10" fill="#2c2c2c"/>
        <path d="M 100 110 Q 95 125 85 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M 100 110 Q 105 125 115 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <circle cx="80" cy="95" r="8" fill="white" stroke="#333" stroke-width="1.5"/>
        <circle cx="80" cy="96" r="5" fill="#2c2c2c"/>
        <circle cx="81" cy="94" r="2" fill="white"/>
        <circle cx="120" cy="95" r="8" fill="white" stroke="#333" stroke-width="1.5"/>
        <circle cx="120" cy="96" r="5" fill="#2c2c2c"/>
        <circle cx="121" cy="94" r="2" fill="white"/>
        <circle cx="55" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
        <circle cx="145" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
        <ellipse cx="100" cy="128" rx="6" ry="8" fill="#ff6b9d"/>
        <path d="M 145 125 Q 165 100 160 70" stroke="#f9a825" stroke-width="12" fill="none" stroke-linecap="round"/>
        <path d="M 145 125 Q 165 100 160 70" stroke="#fdd835" stroke-width="8" fill="none" stroke-linecap="round" opacity="0.8"/>
    </svg>

    <div class="container">
        <div class="header">
            <h1>✨ MY DESTINY PARTNER ✨</h1>
            <p>당신의 성격과 어울리는 앙상블 스타즈 캐릭터를 찾아보세요!</p>
        </div>
        
        <div class="form-container">
            <div class="progress-bar">
                <div class="progress-fill" style="width: 100%"></div>
            </div>
            
            <form action="/match" method="POST" id="quizForm">
                <% 
                const questions = [
                    // Passion (열정) - p1~p5
                    { category: '열정', id: 'p1', q: '라이브 도중 갑작스러운 음향 사고! 당신이 바라는 무대 위 대처는?', l: '침착하게 수습', r: '애드리브로 정면돌파' },
                    { category: '열정', id: 'p2', q: '솔로 파트를 연습하는 아이돌의 등 뒤에서 느껴졌으면 하는 아우라는?', l: '진지하고 은은함', r: '활기차고 이글거림' },
                    { category: '열정', id: 'p3', q: '다음 합동 라이브 기획을 제안받았을 때, 당신이 선호하는 유닛의 성향은?', l: '안정적인 조화', r: '폭발적인 무대 장악력' },
                    { category: '열정', id: 'p4', q: '어려운 안무 미션을 받았을 때, 당신이 선호하는 파트너의 행동은?', l: '동작을 쪼개며 분석', r: '일단 몸으로 부딪히기' },
                    { category: '열정', id: 'p5', q: '무대 커튼콜이 내려간 직후, 파트너와 나누고 싶은 감정은?', l: '안도감과 잔잔한 여운', r: '아드레날린과 뜨거운 전율' },
                    
                    // Elegance (우아함) - e1~e5
                    { category: '우아함', id: 'e1', q: '이번 시즌 유닛의 뉴 비주얼 콘셉트를 고른다면?', l: '캐주얼 & 스트릿', r: '클래식 & 하이클래스' },
                    { category: '우아함', id: 'e2', q: '팬들에게 보내는 공식 인터뷰나 감사 메시지에서 중요한 톤앤매너는?', l: '친근하고 다정한 말투', r: '기품 있고 정중한 태도' },
                    { category: '우아함', id: 'e3', q: '쉬는 날, 파트너와 함께 보낼 완벽한 휴일을 고른다면?', l: '게임방이나 맛집 탐방', r: '미술관 관람이나 티타임' },
                    { category: '우아함', id: 'e4', q: '무대 위 윙크나 팬서비스(오프쇼)에 대한 당신의 생각은?', l: '자유로운 스웩이 최고', r: '각도와 매너까지 완벽해야 함' },
                    { category: '우아함', id: 'e5', q: 'ES 빌딩 복도에서 마주친 당신의 파트너에게서 났으면 하는 향기는?', l: '비누나 은은한 섬유유연제', r: '고급스럽고 세련된 향수' },
                    
                    // Intelligence (지성) - i1~i5
                    { category: '지성', id: 'i1', q: '팬들의 피드백이나 모니터링 데이터를 분석할 때 당신의 방식은?', l: '직관과 감성으로 파악', r: '차트와 통계로 냉정하게 분석' },
                    { category: '지성', id: 'i2', q: '유닛의 새로운 세계관 스토리를 짤 때, 당신이 더 끌리는 서사는?', l: '감성을 자극하는 성장 드라마', r: '복선이 숨겨진 치밀한 추리극' },
                    { category: '지성', id: 'i3', q: '파트너와 깊은 대화를 나눌 때 더 통했으면 하는 부분은?', l: '감정적인 공감과 위로', r: '논리적인 피드백과 아이디어' },
                    { category: '지성', id: 'i4', q: '예산이 한정된 상황에서 대형 무대 연출을 기획해야 한다면?', l: '아이돌의 스타성으로 정면승부', r: '철저한 계산과 특수효과 배치' },
                    { category: '지성', id: 'i5', q: '파트너에게 가장 기대하는 최고의 스펙(Spec)은?', l: '현장을 녹이는 무대 천재력', r: '영리하게 무대를 설계하는 브레인' },
                    
                    // Loyalty (충성) - l1~l5
                    { category: '충성', id: 'l1', q: '서로를 향한 신뢰의 깊이를 확인하는 순간은?', l: '자유롭게 각자의 길을 존중할 때', r: '어떤 위기에도 곁을 지켜줄 때' },
                    { category: '충성', id: 'l2', q: '유닛 멤버들끼리의 규칙이나 약속에 대해 어떻게 생각하나요?', l: '유동적으로 조율 가능', r: '반드시 사수해야 하는 철칙' },
                    { category: '충성', id: 'l3', q: '파트너가 유닛을 대하는 바람직한 태도는?', l: '개인의 개성을 살리는 솔로 플레이어', r: '공동의 목표를 위해 헌신하는 팀플레이어' },
                    { category: '충성', id: 'l4', q: '연습실에 가장 먼저 도착해 불을 켜는 파트너를 보았을 때 드는 생각은?', l: '성실하네! (기본적인 느낌)', r: '정말 든든하고 신뢰가 가! (깊은 감동)' },
                    { category: '충성', id: 'l5', q: '스케줄이 꼬여 파트너가 무리한 대타 무대를 소화해야 한다면?', l: '컨디션을 조절해가며 적당히', r: '자신의 이름을 걸고 완벽하게 책임짐' },
                    
                    // Freedom (자유) - f1~f5
                    { category: '자유', id: 'f1', q: '당일 야외 촬영인데 갑자기 폭우가 쏟아진다면?', l: '실내 스튜디오 대안 고수', r: '비 콘셉트의 즉흥 촬영으로 변경' },
                    { category: '자유', id: 'f2', q: '아이돌의 철저한 식단 관리와 데일리 루틴에 대한 당신의 견해는?', l: '계획대로 엄격하게 유지', r: '스트레스 받지 않게 유연하게 힐링' },
                    { category: '자유', id: 'f3', q: 'ES 빌딩의 빡빡한 가이드라인과 규칙을 볼 때 드는 생각은?', l: '안전을 위해 꼭 필요함', r: '때로는 창의성을 가로막아 답답함' },
                    { category: '자유', id: 'f4', q: '새로운 장르(예: 국악 혼합 힙합 등)의 곡을 마주했을 때 당신은?', l: '검증된 스타일인지 검토 후 진행', r: '재밌겠는데? 일단 녹음실로 직행' },
                    { category: '자유', id: 'f5', q: '예상치 못한 게릴라 라이브나 깜짝 버스킹 제안을 받는다면?', l: '리스크가 크니 다음 기회에', r: '이게 바로 아이돌의 짜릿함! 당장 진행' }
                ];
                %>

                <% questions.forEach((item, index) => { %>
                    <div class="q-card">
                        <span class="category-label"><%= item.category %></span>
                        <span class="q-number"><%= index + 1 %></span><span class="q-text"><%= item.q %></span>
                        <div class="options">
                            <span class="hint left"><%= item.l %></span>
                            <label class="option-label opt-1"><input type="radio" name="<%= item.id %>" value="0" required><div class="circle"></div></label>
                            <label class="option-label opt-2"><input type="radio" name="<%= item.id %>" value="2.5"><div class="circle"></div></label>
                            <label class="option-label opt-3"><input type="radio" name="<%= item.id %>" value="5"><div class="circle"></div></label>
                            <label class="option-label opt-4"><input type="radio" name="<%= item.id %>" value="7.5"><div class="circle"></div></label>
                            <label class="option-label opt-5"><input type="radio" name="<%= item.id %>" value="10" required><div class="circle"></div></label>
                            <span class="hint right"><%= item.r %></span>
                        </div>
                    </div>
                <% }); %>

                <button type="submit">나의 운명의 파트너 찾기</button>
            </form>
            <script>
                (function(){
                    const Audioctx = window.AudioContext || window.webkitAudioContext;
                    let ctx;
                    function getCtx(){ if(!ctx) ctx = new Audioctx(); return ctx; }

                    function playClick(){
                        const c = getCtx();
                        const o = c.createOscillator();
                        const g = c.createGain();
                        o.type = 'square'; o.frequency.value = 900;
                        g.gain.value = 0.02;
                        o.connect(g); g.connect(c.destination);
                        o.start(); setTimeout(()=>{ o.stop(); }, 60);
                    }

                    function playSubmit(){
                        const c = getCtx(); const now = c.currentTime;
                        const master = c.createGain(); master.connect(c.destination);
                        master.gain.setValueAtTime(0, now);
                        master.gain.linearRampToValueAtTime(0.06, now + 0.01);
                        master.gain.linearRampToValueAtTime(0, now + 0.35);
                        const o = c.createOscillator(); o.type='sine'; o.frequency.setValueAtTime(440, now);
                        o.connect(master); o.start(now); o.stop(now + 0.35);
                    }

                    document.addEventListener('DOMContentLoaded', ()=>{
                        // 클릭/선택 사운드
                        document.querySelectorAll('label.option-label').forEach(el=>{
                            el.addEventListener('click', ()=>{ try{ playClick(); }catch(e){} });
                        });

                        const form = document.getElementById('quizForm');
                        if(form){
                            form.addEventListener('submit', (e)=>{
                                try{ playSubmit(); }catch(e){}
                            });
                        }
                    });
                })();
            </script>
        </div>
    </div>
</body>
</html>
