    choices:[
        {key:'A',text:'혼자 시간을 준다',score:0},
        {key:'B',text:'필요하면 도와준다',score:3},
        {key:'C',text:'끝까지 함께한다',score:7},
        {key:'D',text:'무슨 일이든 대신 짊어진다',score:10},
    ]
}

];

let current = 0;
let answers = new Array(questions.length).fill(null);

function renderQuestion(){

    const q = questions[current];

    document.getElementById('question').textContent =
        `Q${current+1}. ${q.q}`;

    document.getElementById('badge').textContent = q.cat;

    document.getElementById('categoryLabel').textContent = q.cat;

    document.getElementById('progressLabel').textContent =
        `${current+1} / ${questions.length}`;

    document.getElementById('progress').style.width =
        `${((current+1)/questions.length)*100}%`;

    const choicesEl = document.getElementById('choices');

    choicesEl.innerHTML = '';

    q.choices.forEach(choice => {

        const btn = document.createElement('button');

        btn.className =
            'choice-btn' +
            (answers[current] === choice.key ? ' selected' : '');

        btn.innerHTML = `
            <div class="choice-key">${choice.key}</div>
            <div class="choice-text">${choice.text}</div>
        `;

        btn.onclick = () => selectChoice(choice.key);

        choicesEl.appendChild(btn);
    });

    const nextBtn = document.getElementById('nextBtn');

    nextBtn.classList.toggle(
        'active',
        answers[current] !== null
    );

    if(current === questions.length - 1){
        nextBtn.textContent = '결과 보기 🎉';
    }else{
        nextBtn.textContent = '다음 →';
    }
}

function selectChoice(key){

    answers[current] = key;

    renderQuestion();
}

function nextQuestion(){

    if(answers[current] === null) return;

    if(current < questions.length - 1){

        current++;
        renderQuestion();

    }else{

        submitQuiz();
    }
}

function prevQuestion(){

    if(current > 0){

        current--;
        renderQuestion();
    }
}

function submitQuiz(){

    const form = document.getElementById('hiddenForm');

    form.innerHTML = '';

    questions.forEach((q,index)=>{

        const selectedKey = answers[index];

        const selectedChoice =
            q.choices.find(c => c.key === selectedKey);

        const input = document.createElement('input');

        input.type = 'hidden';
        input.name = q.id;
        input.value = selectedChoice.score;

        form.appendChild(input);
    });

    form.submit();
}

renderQuestion();

</script>

</body>
</html>