<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>앙상블 스타즈 성격 테스트 - 내 운명의 파트너는?</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        :root {
            --main-color: #3b82f6;
            --bg-gradient: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
            --shadow: 0 20px 60px rgba(59, 130, 246, 0.1);
        }
        
        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: var(--bg-gradient);
            color: #333;
            padding: 20px;
            min-height: 100vh;
        }
        
        .container {
            max-width: 800px;
            margin: 0 auto;
        }
        
        .header {
            text-align: center;
            margin-bottom: 50px;
            animation: fadeIn 0.6s ease-out;
        }
        
        .header h1 {
            font-size: 2.5em;
            color: var(--main-color);
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(255, 0, 85, 0.1);
        }
        
        .header p {
            font-size: 1.1em;
            color: #666;
        }
        
        .progress-bar {
            background: #eee;
            height: 6px;
            border-radius: 10px;
            margin-bottom: 40px;
            overflow: hidden;
        }
        
        .progress-fill {
            height: 100%;
            background: linear-gradient(90deg, var(--main-color), #ff3399);
            border-radius: 10px;
            transition: width 0.3s ease;
        }
        
        .form-container {
            background: white;
            padding: 40px;
            border-radius: 20px;
            box-shadow: var(--shadow);
            margin-bottom: 30px;
        }
        
        .q-card {
            margin-bottom: 40px;
            padding-bottom: 40px;
            border-bottom: 2px solid #f0f0f0;
            animation: slideIn 0.5s ease-out;
        }
        
        .q-card:last-child {
            border-bottom: none;
        }
        
        .category-label {
            display: none;
            background: var(--main-color);
            color: white;
            padding: 5px 15px;
            border-radius: 20px;
            font-size: 0.8em;
            font-weight: bold;
            margin-bottom: 10px;
        }
        
        .q-number {
            display: inline-block;
            background: var(--main-color);
            color: white;
            width: 36px;
            height: 36px;
            border-radius: 50%;
            text-align: center;
            line-height: 36px;
            font-weight: bold;
            margin-right: 10px;
            font-size: 0.9em;
        }
        
        .q-text {
            display: inline-block;
            font-size: 1.05em;
            font-weight: 600;
            color: #333;
            line-height: 1.6;
        }
        
        .options {
            display: flex;
            justify-content: space-between;
            align-items: flex-end;
            margin-top: 25px;
            gap: 10px;
            flex-wrap: wrap;
        }
        
        .hint {
            font-size: 0.85em;
            color: #999;
            font-weight: 600;
            text-align: center;
            flex: 0 0 12%;
            min-width: 60px;
        }
        
        .hint.left { flex: 0 0 18%; }
        .hint.right { flex: 0 0 18%; }
        
        .option-label {
            cursor: pointer;
            display: flex;
            flex-direction: column;
            align-items: center;
            flex: 1;
            min-width: 45px;
            transition: 0.3s;
        }
        
        .option-label:hover .circle {
            transform: scale(1.2);
        }
        
        .option-label input {
            display: none;
        }
        
        .circle {
            border: 3px solid #ddd;
            border-radius: 50%;
            background: #fff;
            transition: all 0.3s ease;
            cursor: pointer;
            box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
        }
        
        .opt-1 .circle { width: 50px; height: 50px; }
        .opt-2 .circle { width: 42px; height: 42px; }
        .opt-3 .circle { width: 34px; height: 34px; }
        .opt-4 .circle { width: 42px; height: 42px; }
        .opt-5 .circle { width: 50px; height: 50px; }
        
        .option-label input:checked + .circle {
            background: var(--main-color);
            border-color: var(--main-color);
            box-shadow: 0 0 20px rgba(255, 0, 85, 0.4);
            transform: scale(1.15);
        }
        
        button {
            background: linear-gradient(135deg, var(--main-color), #ff3399);
            color: #fff;
            border: none;
            padding: 16px 40px;
            width: 100%;
            max-width: 300px;
            border-radius: 50px;
            font-size: 1.2em;
            font-weight: bold;
            cursor: pointer;
            transition: 0.3s;
            display: block;
            margin: 40px auto 0;
            box-shadow: 0 8px 20px rgba(255, 0, 85, 0.3);
        }
        
        button:hover {
            transform: translateY(-3px);
            box-shadow: 0 12px 30px rgba(255, 0, 85, 0.4);
        }
        
        button:active {
            transform: translateY(-1px);
        }
        
        @keyframes fadeIn {
            from { opacity: 0; transform: translateY(-20px); }
            to { opacity: 1; transform: translateY(0); }
        }
        
        @keyframes slideIn {
            from { opacity: 0; transform: translateX(-20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        /* 모바일 반응형 (태블릿 이하) */
        @media (max-width: 768px) {
            .container {
                max-width: 100%;
                padding: 0;
            }

            .header {
                margin-bottom: 30px;
                padding: 20px;
            }

            .header h1 {
                font-size: 1.8em;
                margin-bottom: 8px;
            }

            .header p {
                font-size: 0.95em;
            }

            .form-container {
                padding: 20px;
                margin-bottom: 20px;
                border-radius: 15px;
            }

            .q-card {
                margin-bottom: 25px;
                padding-bottom: 25px;
            }

            .q-number {
                width: 30px;
                height: 30px;
                line-height: 30px;
                font-size: 0.85em;
                margin-right: 8px;
            }

            .q-text {
                font-size: 0.95em;
                line-height: 1.5;
            }

            .options {
                flex-direction: column;
                align-items: stretch;
                gap: 15px;
                margin-top: 20px;
            }

            .hint {
                display: none;
            }

            .hint.left,
            .hint.right {
                display: none;
            }

            .option-label {
                flex: 1;
                padding: 10px;
                border: 2px solid #eee;
                border-radius: 10px;
                text-align: left;
                flex-direction: row;
                align-items: center;
                gap: 10px;
            }

            .option-label:hover {
                background: #f9f9f9;
            }

            .option-label input:checked + .circle {
                box-shadow: 0 0 15px rgba(255, 0, 85, 0.4);
            }

            .opt-1 .circle { width: 40px; height: 40px; }
            .opt-2 .circle { width: 40px; height: 40px; }
            .opt-3 .circle { width: 40px; height: 40px; }
            .opt-4 .circle { width: 40px; height: 40px; }
            .opt-5 .circle { width: 40px; height: 40px; }

            button {
                max-width: none;
                padding: 14px 30px;
                font-size: 1.1em;
                margin: 30px auto 0;
                width: 90%;
            }

            body {
                padding: 10px;
            }
        }

        /* 작은 모바일 (480px 이하) */
        @media (max-width: 480px) {
            .container {
                max-width: 100%;
                padding: 0;
            }

            .header {
                margin-bottom: 20px;
                padding: 15px;
            }

            .header h1 {
                font-size: 1.5em;
                margin-bottom: 5px;
            }

            .header p {
                font-size: 0.9em;
            }

            .form-container {
                padding: 15px;
                margin-bottom: 15px;
                border-radius: 12px;
            }

            .progress-bar {
                height: 5px;
                margin-bottom: 25px;
            }

            .q-card {
                margin-bottom: 20px;
                padding-bottom: 20px;
            }

            .category-label {
                font-size: 0.75em;
                padding: 4px 12px;
                margin-bottom: 8px;
            }

            .q-number {
                width: 28px;
                height: 28px;
                line-height: 28px;
                font-size: 0.8em;
                margin-right: 6px;
            }

            .q-text {
                font-size: 0.9em;
                line-height: 1.4;
            }

            .option-label {
                padding: 8px;
                border-radius: 8px;
                gap: 8px;
                font-size: 0.9em;
            }

            .opt-1 .circle { width: 35px; height: 35px; }
            .opt-2 .circle { width: 35px; height: 35px; }
            .opt-3 .circle { width: 35px; height: 35px; }
            .opt-4 .circle { width: 35px; height: 35px; }
            .opt-5 .circle { width: 35px; height: 35px; }

            button {
                max-width: none;
                padding: 12px 24px;
                font-size: 1em;
                margin: 25px auto 0;
                width: 95%;
            }

            body {
                padding: 8px;
            }
        }

        /* 강아지 데코레이션 */
        .dog-decoration {
            position: fixed;
            pointer-events: none;
            opacity: 0.8;
        }

        .dog-top-left {
            top: 20px;
            left: 20px;
            width: 60px;
            height: 60px;
        }

        .dog-bottom-right {
            bottom: 30px;
            right: 20px;
            width: 80px;
            height: 80px;
            opacity: 0.6;
            animation: float 3s ease-in-out infinite;
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px) rotate(0deg);
            }
            50% {
                transform: translateY(-15px) rotate(2deg);
            }
        }
    </style>
</head>
<body>
    <!-- 강아지 데코레이션 -->
    <svg class="dog-decoration dog-top-left" viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
        <ellipse cx="100" cy="110" rx="55" ry="58" fill="#fdd835" stroke="#f9a825" stroke-width="2"/>
        <ellipse cx="60" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(-20 60 55)"/>
        <ellipse cx="62" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(-20 62 58)"/>
        <ellipse cx="140" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(20 140 55)"/>
        <ellipse cx="138" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(20 138 58)"/>
        <ellipse cx="100" cy="110" rx="8" ry="10" fill="#2c2c2c"/>
        <path d="M 100 110 Q 95 125 85 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <path d="M 100 110 Q 105 125 115 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
        <circle cx="80" cy="95" r="8" fill="white" stroke="#333" stroke-width="1.5"/>
