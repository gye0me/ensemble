<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>앙상블 스타즈 성격 테스트 - 시작</title>
    <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+KR:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --main-color: #3b82f6;
            --bg-gradient: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
            --shadow: 0 20px 60px rgba(59, 130, 246, 0.1);
        }

        body {
            font-family: 'Noto Sans KR', sans-serif;
            background: var(--bg-gradient);
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 20px;
        }

        .container {
            text-align: center;
            max-width: 500px;
            animation: fadeIn 0.8s ease-out;
        }

        .dog-container {
            margin-bottom: 40px;
            animation: float 3s ease-in-out infinite;
        }

        svg {
            width: 180px;
            height: 180px;
            filter: drop-shadow(0 10px 20px rgba(59, 130, 246, 0.2));
        }

        h1 {
            font-size: 2.5em;
            color: var(--main-color);
            margin-bottom: 15px;
            font-weight: 900;
            text-shadow: 2px 2px 4px rgba(59, 130, 246, 0.1);
        }

        .subtitle {
            font-size: 1.2em;
            color: #666;
            margin-bottom: 30px;
            line-height: 1.6;
        }

        .description {
            background: rgba(255, 255, 255, 0.7);
            padding: 25px;
            border-radius: 15px;
            margin-bottom: 40px;
            border: 2px solid rgba(59, 130, 246, 0.1);
            font-size: 0.95em;
            color: #555;
            line-height: 1.8;
        }

        .features {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 15px;
            margin-bottom: 40px;
        }

        .feature {
            background: white;
            padding: 15px;
            border-radius: 12px;
            box-shadow: 0 5px 15px rgba(59, 130, 246, 0.08);
        }

        .feature-icon {
            font-size: 2em;
            margin-bottom: 8px;
        }

        .feature-text {
            font-size: 0.85em;
            color: #666;
            font-weight: 600;
        }

        .button {
            background: linear-gradient(135deg, var(--main-color), #2563eb);
            color: white;
            border: none;
            padding: 18px 50px;
            font-size: 1.15em;
            font-weight: 700;
            border-radius: 50px;
            cursor: pointer;
            transition: all 0.3s ease;
            box-shadow: 0 10px 30px rgba(59, 130, 246, 0.3);
            display: inline-block;
            text-decoration: none;
        }

        .button:hover {
            transform: translateY(-3px);
            box-shadow: 0 15px 40px rgba(59, 130, 246, 0.4);
        }

        .button:active {
            transform: translateY(-1px);
        }

        @keyframes fadeIn {
            from {
                opacity: 0;
                transform: translateY(30px);
            }
            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @keyframes float {
            0%, 100% {
                transform: translateY(0px);
            }
            50% {
                transform: translateY(-15px);
            }
        }

        @media (max-width: 768px) {
            h1 {
                font-size: 1.8em;
            }

            .subtitle {
                font-size: 1.05em;
            }

            svg {
                width: 140px;
                height: 140px;
            }

            .features {
                grid-template-columns: 1fr;
            }

            .button {
                width: 100%;
                padding: 16px 30px;
                font-size: 1.05em;
            }
        }

        @media (max-width: 480px) {
            h1 {
                font-size: 1.5em;
            }

            .subtitle {
                font-size: 0.95em;
            }

            svg {
                width: 120px;
                height: 120px;
            }

            .description {
                padding: 18px;
                font-size: 0.9em;
            }

            .button {
                width: 100%;
                padding: 14px 24px;
                font-size: 1em;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="dog-container">
            <svg viewBox="0 0 200 200" xmlns="http://www.w3.org/2000/svg">
                <!-- 얼굴 -->
                <ellipse cx="100" cy="110" rx="55" ry="58" fill="#fdd835" stroke="#f9a825" stroke-width="2"/>
                
                <!-- 왼쪽 귀 -->
                <ellipse cx="60" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(-20 60 55)"/>
                <ellipse cx="62" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(-20 62 58)"/>
                
                <!-- 오른쪽 귀 -->
                <ellipse cx="140" cy="55" rx="18" ry="35" fill="#f9a825" stroke="#f57c00" stroke-width="2" transform="rotate(20 140 55)"/>
                <ellipse cx="138" cy="58" rx="10" ry="20" fill="#ffb74d" transform="rotate(20 138 58)"/>
                
                <!-- 코 -->
                <ellipse cx="100" cy="110" rx="8" ry="10" fill="#2c2c2c"/>
                
                <!-- 입 -->
                <path d="M 100 110 Q 95 125 85 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                <path d="M 100 110 Q 105 125 115 120" stroke="#2c2c2c" stroke-width="2.5" fill="none" stroke-linecap="round"/>
                
                <!-- 왼쪽 눈 -->
                <circle cx="80" cy="95" r="8" fill="white" stroke="#333" stroke-width="1.5"/>
                <circle cx="80" cy="96" r="5" fill="#2c2c2c"/>
                <circle cx="81" cy="94" r="2" fill="white"/>
                
                <!-- 오른쪽 눈 -->
                <circle cx="120" cy="95" r="8" fill="white" stroke="#333" stroke-width="1.5"/>
                <circle cx="120" cy="96" r="5" fill="#2c2c2c"/>
                <circle cx="121" cy="94" r="2" fill="white"/>
                
                <!-- 왼쪽 볼 -->
                <circle cx="55" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
                
                <!-- 오른쪽 볼 -->
                <circle cx="145" cy="110" r="12" fill="#ffb74d" opacity="0.5"/>
                
                <!-- 혀 -->
                <ellipse cx="100" cy="128" rx="6" ry="8" fill="#ff6b9d"/>
                
                <!-- 목 -->
                <rect x="80" y="155" width="40" height="15" fill="#fdd835" stroke="#f9a825" stroke-width="2" rx="3"/>
                
                <!-- 왼쪽 앞다리 -->
                <rect x="70" y="155" width="12" height="30" fill="#f9a825" stroke="#f57c00" stroke-width="2" rx="6"/>
                <ellipse cx="76" cy="188" rx="8" ry="6" fill="#f57c00"/>
                
                <!-- 오른쪽 앞다리 -->
                <rect x="118" y="155" width="12" height="30" fill="#f9a825" stroke="#f57c00" stroke-width="2" rx="6"/>
                <ellipse cx="124" cy="188" rx="8" ry="6" fill="#f57c00"/>
                
                <!-- 꼬리 -->
                <path d="M 145 125 Q 165 100 160 70" stroke="#f9a825" stroke-width="12" fill="none" stroke-linecap="round"/>
                <path d="M 145 125 Q 165 100 160 70" stroke="#fdd835" stroke-width="8" fill="none" stroke-linecap="round" opacity="0.8"/>
                
                <!-- 행복 빛 -->
                <circle cx="50" cy="80" r="3" fill="#ffd700" opacity="0.6"/>
                <circle cx="150" cy="70" r="2.5" fill="#ffd700" opacity="0.6"/>
                <circle cx="160" cy="90" r="2" fill="#ffd700" opacity="0.5"/>
            </svg>
        </div>

        <h1>✨ MY DESTINY PARTNER ✨</h1>
        <p class="subtitle">당신의 성격과 어울리는<br/>앙상블 스타즈 캐릭터를 찾아보세요!</p>

        <div class="description">
            🎭 25개의 성격 질문을 통해 당신과 가장 잘 맞는 캐릭터를 찾아드립니다.<br/>
            💕 당신의 열정, 우아함, 지성, 충성, 자유의 성향을 분석해봅시다!
        </div>

        <div class="features">
            <div class="feature">
                <div class="feature-icon">📊</div>
                <div class="feature-text">5가지 성격 분석</div>
            </div>
            <div class="feature">
                <div class="feature-icon">💫</div>
                <div class="feature-text">호환도 계산</div>
            </div>
            <div class="feature">
                <div class="feature-icon">🎭</div>
                <div class="feature-text">40+ 캐릭터</div>
            </div>
            <div class="feature">
                <div class="feature-icon">⚡</div>
                <div class="feature-text">즉시 결과</div>
            </div>
        </div>

        <button id="startBtn" class="button">시작하기</button>
    </div>

    <script>
        (function(){
            const Audioctx = window.AudioContext || window.webkitAudioContext;
            let ctx;
            function getCtx(){ if(!ctx) ctx = new Audioctx(); return ctx; }

            function playClick(){
                const c = getCtx();
                const o = c.createOscillator();
                const g = c.createGain();
                o.type = 'sine';
                o.frequency.value = 900;
                g.gain.value = 0.02;
                o.connect(g); g.connect(c.destination);
                o.start();
                setTimeout(()=>{ o.stop(); }, 80);
            }

            function playStartJingle(){
                const c = getCtx();
                const now = c.currentTime;
                const master = c.createGain(); master.connect(c.destination);
                master.gain.setValueAtTime(0, now);
                master.gain.linearRampToValueAtTime(0.07, now + 0.02);
                master.gain.linearRampToValueAtTime(0, now + 0.6);

                const freqs = [520, 660, 820];
                freqs.forEach((f, i) => {
                    const o = c.createOscillator();
                    o.type = 'triangle';
                    o.frequency.setValueAtTime(f, now + i * 0.08);
                    o.connect(master);
                    o.start(now + i * 0.08);
                    o.stop(now + i * 0.08 + 0.18);
                });

                return new Promise(resolve => setTimeout(resolve, 700));
            }

            document.addEventListener('DOMContentLoaded', ()=>{
                const btn = document.getElementById('startBtn');
                if(!btn) return;
                btn.addEventListener('click', async (e)=>{
                    e.preventDefault();
                    playClick();
                    await playStartJingle();
                    window.location.href = '/quiz';
                });
            });

            window.playClick = playClick;
        })();
    </script>
</body>
</html>
